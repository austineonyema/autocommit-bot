{
  "name": "git-autocommit-flow",
  "version": "0.1.0",
  "description": "Branch-aware auto-commit daemon with optional auto-push and AI-style commit summaries.",
  "type": "module",
  "main": "./dist/cli.js",
  "types": "./dist/cli.d.ts",
  "bin": {
    "autocommit": "./bin/autocommit.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "start": "npm run build && node ./bin/autocommit.js",
    "watch": "npm run build && node ./bin/autocommit.js watch",
    "check": "tsc --noEmit -p tsconfig.json",
    "test:smoke": "npm run build && node ./bin/autocommit.js --help",
    "prepublishOnly": "npm run check && npm run test:smoke"
  },
  "keywords": [
    "git",
    "autocommit",
    "automation",
    "watcher",
    "cli"
  ],
  "files": [
    "bin/",
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "chokidar": "^3.6.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.2"
  }
}
